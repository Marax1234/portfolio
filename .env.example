# Lokale Entwicklungsvariablen für Sprint 4 (Payload-Datenmodell & Admin).
# Kopieren nach `.env` und ggf. anpassen — `.env` ist gitignored.

# Verbindung zur lokalen Dev-Postgres (siehe docker-compose.dev.yml / pnpm db:up)
DATABASE_URI=postgres://portfolio:portfolio@localhost:5432/portfolio

# Payload-Secret zum Signieren von Sessions/Tokens — pro Umgebung einzigartig,
# niemals committen. Beispiel zum Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=changeme

NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Seed-Admin-User (nur lokal, siehe src/seed/index.ts)
SEED_ADMIN_EMAIL=admin@kilian-siebert.de
SEED_ADMIN_PASSWORD=changeme123

# Object Storage (Sprint 7 — MinIO im Docker-Container, siehe docker-compose.dev.yml).
# Werte unten passen zu den MinIO-Dev-Defaults aus docker-compose.dev.yml.
S3_BUCKET=portfolio-media
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9100
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
# Öffentliche Basis-URL, von der das Frontend Bilder direkt lädt (kein Payload-Proxy).
NEXT_PUBLIC_S3_PUBLIC_URL=http://localhost:9100/portfolio-media

# FFmpeg-Docker-Image für die HLS-Transkodierung (Sprint 8).
# Vorab ziehen: docker pull jrottenberg/ffmpeg:6.1-ubuntu2204
FFMPEG_DOCKER_IMAGE=jrottenberg/ffmpeg:6.1-ubuntu2204

# Umami-Statistik (Sprint 10 — nur Deployment, lokal inert).
# Tracker-Script (Frontend):
#   NEXT_PUBLIC_UMAMI_SRC  → URL des Umami-Tracker-Scripts (z. B. https://umami.example.com/script.js)
#   NEXT_PUBLIC_UMAMI_WEBSITE_ID → Website-ID aus dem Umami-Dashboard
# Admin-API (Server-only, nicht NEXT_PUBLIC):
#   UMAMI_API_URL      → Basis-URL des Umami-Servers (z. B. https://umami.example.com)
#   UMAMI_API_TOKEN    → API-Token (Umami: Settings → API Keys)
#   UMAMI_WEBSITE_ID   → Website-ID (identisch mit NEXT_PUBLIC_UMAMI_WEBSITE_ID)
# NEXT_PUBLIC_UMAMI_SRC=https://umami.example.com/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# UMAMI_API_URL=https://umami.example.com
# UMAMI_API_TOKEN=
# UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# E-Mail (Sprint 9 — Kontaktanfragen-Benachrichtigung)
# Ohne SMTP_HOST → Ethereal-Testaccount (Preview-URL im Server-Log, kein echter Versand).
# Mit SMTP_HOST → echter Versand über den angegebenen SMTP-Server.
# Produtiver Anbieter (Resend, Postmark, etc.) wird im Deployment konfiguriert
# (Sprintplan §4 „Post-Development: E-Mail produktiv").
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM=noreply@kilian-siebert.de
EMAIL_FROM_NAME=Kilian Siebert Portfolio
# Empfänger der Admin-Benachrichtigung bei neuer Kontaktanfrage.
# Standard-Fallback: SEED_ADMIN_EMAIL
CONTACT_NOTIFY_TO=admin@kilian-siebert.de
