# Lokale Entwicklungsvariablen für Sprint 4 (Payload-Datenmodell & Admin).
# Kopieren nach `.env` und ggf. anpassen — `.env` ist gitignored.

# Verbindung zur lokalen Dev-Postgres (siehe docker-compose.dev.yml / pnpm db:up)
DATABASE_URI=postgres://portfolio:portfolio@localhost:5432/portfolio

# Payload-Secret zum Signieren von Sessions/Tokens — pro Umgebung einzigartig,
# niemals committen. Beispiel zum Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=changeme

NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Seed-Admin-User (nur lokal, siehe src/seed/index.ts)
SEED_ADMIN_EMAIL=admin@kilian-siebert.de
SEED_ADMIN_PASSWORD=changeme123

# Object Storage (Sprint 7 — MinIO im Docker-Container, siehe docker-compose.dev.yml).
# Werte unten passen zu den MinIO-Dev-Defaults aus docker-compose.dev.yml.
S3_BUCKET=portfolio-media
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9100
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
# Öffentliche Basis-URL, von der das Frontend Bilder direkt lädt (kein Payload-Proxy).
NEXT_PUBLIC_S3_PUBLIC_URL=http://localhost:9100/portfolio-media
